# ============================================
# PropEase Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server Port
PORT=5000

# MongoDB Connection String
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/propease
MONGO_URI=mongodb://localhost:27017/propease

# JWT Secret Key - use any long random string
# IMPORTANT: Change this in production!
JWT_SECRET=propease_super_secret_key_change_in_production

# JWT Expiry - how long a login token lasts
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
